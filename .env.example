# =====================================================
#  FuzzyRide — biến môi trường
#  Cách dùng (PowerShell):
#    $env:GOOGLE_CLIENT_ID="123456-abc.apps.googleusercontent.com"
#    $env:FACEBOOK_APP_ID="987654321"
#    $env:FACEBOOK_APP_SECRET="..."
#    python app.py
#  Hoặc copy file này thành .env rồi load qua python-dotenv (cài thêm).
# =====================================================

# ----- Flask -----
FUZZYRIDE_SECRET=change-me-to-random-32-chars-string

# ----- Google Sign-In -----
# 1. Vào https://console.cloud.google.com/apis/credentials
# 2. Create Credentials → OAuth client ID → Web application
# 3. Authorized JavaScript origins: http://localhost:5000
# 4. Authorized redirect URIs: http://localhost:5000  (không cần redirect cho One Tap)
# 5. Copy Client ID dán vào đây:
GOOGLE_CLIENT_ID=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

# ----- Facebook Login -----
# 1. Vào https://developers.facebook.com/apps/ → Create App → Consumer
# 2. Add Product → Facebook Login → Web
# 3. Site URL: http://localhost:5000
# 4. Settings → Basic → copy App ID & App Secret
FACEBOOK_APP_ID=1425412315935528
FACEBOOK_APP_SECRET=6312dea05d55ef60f2767e2e92c7d1cb
